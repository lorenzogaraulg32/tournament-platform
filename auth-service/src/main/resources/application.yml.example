server:
  port: 8081

spring:
  application:
    name: auth-service
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/auth_service_db
    username: db_username
    password: "db_password"
  jpa:
   hibernate.ddl-auto: update
   generate-ddl: true
   show-sql: true

security:
  jwt:
    secret: "your secret"

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/

